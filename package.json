{
  "name": "vividcraft",
  "version": "1.0.0",
  "private": true,
  "description": "VividCraft - Distributed Microservices Digital Art & Comic Marketplace",
  "scripts": {
    "dev": "docker compose up --build",
    "dev:detached": "docker compose up --build -d",
    "dev:down": "docker compose down",
    "dev:logs": "docker compose logs -f",
    "dev:clean": "docker compose down -v --remove-orphans",
    "dev:obs": "docker compose -f docker-compose.yml -f docker-compose.observability.yml up --build -d",
    "dev:obs:down": "docker compose -f docker-compose.yml -f docker-compose.observability.yml down",
    "install:all": "npm run install:auth && npm run install:marketplace && npm run install:transaction && npm run install:gateway && npm run install:web",
    "install:auth": "cd services/auth-service && npm install",
    "install:marketplace": "cd services/marketplace-service && npm install",
    "install:transaction": "cd services/transaction-service && npm install",
    "install:gateway": "cd services/api-gateway && npm install",
    "install:web": "cd apps/web-client && npm install",
    "test:gateway": "cd services/api-gateway && npm test",
    "test:scan": "cd services/marketplace-service && npx ts-node --transpile-only src/redis/redis.scan.test.ts",
    "test:web": "cd apps/web-client && npm test",
    "test:unit": "npm run test:gateway && npm run test:scan && npm run test:web",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test -c tests/e2e/playwright.config.ts --ui",
    "test": "npm run test:unit && npm run test:e2e",
    "synthetic": "node tests/synthetic/checkout-flow.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
