# Root environment variables (used by docker-compose)
POSTGRES_USER=vividcraft
POSTGRES_PASSWORD=vividcraft_secret
POSTGRES_DB=vividcraft_auth
POSTGRES_TRANSACTION_DB=vividcraft_transactions

MONGO_INITDB_ROOT_USERNAME=vividcraft
MONGO_INITDB_ROOT_PASSWORD=vividcraft_secret
MONGO_DB=vividcraft_marketplace

REDIS_HOST=redis
REDIS_PORT=6379

API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
MARKETPLACE_SERVICE_PORT=3002
TRANSACTION_SERVICE_PORT=3003
IMAGE_PROCESSOR_PORT=5000
WEB_CLIENT_PORT=5173

JWT_SECRET=change-this-to-a-secure-random-secret-in-production
JWT_EXPIRES_IN=7d

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:5173/orders?paid=1
STRIPE_CANCEL_URL=http://localhost:5173/cart?cancelled=1

# FX rate for checkout IDR display (catalog prices are USD)
USD_TO_IDR=16000

# Xendit (test keys from https://dashboard.xendit.co/settings/developers#api-keys)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_CURRENCY=idr
XENDIT_SUCCESS_URL=http://localhost:5173/orders?paid=1
XENDIT_CANCEL_URL=http://localhost:5173/cart?cancelled=1

IMAGE_PROCESSOR_URL=http://image-processor:5000
