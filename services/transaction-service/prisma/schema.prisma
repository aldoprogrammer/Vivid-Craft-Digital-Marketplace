generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  userEmail   String
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  invoiceNo   String      @unique
  items       OrderItem[]
  payment     Payment?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  productType String
  creatorId   String?
  price       Decimal @db.Decimal(10, 2)
  quantity    Int     @default(1)

  @@unique([orderId, productId])
  @@index([creatorId])
  @@map("order_items")
}

model Payment {
  id                   String        @id @default(uuid())
  orderId              String        @unique
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount               Decimal       @db.Decimal(10, 2)
  status               PaymentStatus @default(PENDING)
  transactionId        String        @unique
  method               String        @default("SIMULATED")
  stripeSessionId      String?
  stripePaymentIntentId String?
  processedAt          DateTime?
  createdAt            DateTime      @default(now())

  @@map("payments")
}

model PurchaseLock {
  id        String   @id @default(uuid())
  userId    String
  productId String
  orderId   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("purchase_locks")
}

model DigitalDelivery {
  id             String   @id @default(uuid())
  userId         String
  orderId        String
  orderItemId    String   @unique
  productId      String
  productName    String
  productType    String
  invoiceNo      String
  downloadToken  String   @unique
  downloadCount  Int      @default(0)
  assetFileUrl   String?
  assetFileName  String?
  assetMimeType  String?
  deliveredAt    DateTime @default(now())
  lastDownloadAt DateTime?

  @@index([userId])
  @@unique([userId, productId])
  @@map("digital_deliveries")
}

model ProductReview {
  id          String   @id @default(uuid())
  productId   String
  productName String
  creatorId   String
  authorId    String
  authorName  String
  authorRole  String
  rating      Int?
  comment     String
  parentId    String?
  parent      ProductReview?  @relation("ReviewThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies     ProductReview[] @relation("ReviewThread")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([creatorId])
  @@index([authorId])
  @@index([parentId])
  @@map("product_reviews")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  linkPath  String?
  payload   Json?
  eventId   String?   @unique
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
