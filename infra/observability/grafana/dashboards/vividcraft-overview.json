{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["vividcraft"],
  "title": "VividCraft Overview",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targets Up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] },
      "targets": [{ "expr": "sum(up)", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Request Rate by Service",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (service) (rate(http_requests_total[5m]))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP 5xx Rate by Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (service) (rate(http_requests_total{status_code=~\"5..\"}[5m]))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p95 Request Duration by Service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Service Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{project=\"vividcraft\"}", "refId": "A" }]
    }
  ]
}
